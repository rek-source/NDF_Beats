# NDF Beats — local environment. Copy to .env to override defaults.
# The APP runs with NO env at all. The keys below are used ONLY by the optional
# REAL data ingestion (scripts/ingest.js); the running server never reads them.

# HTTP port the Express server listens on.
PORT=4178

# SQLite database file path (relative paths resolve from the repo root).
DB_PATH=data/ndf-beats.db

# ── Rep identity (PIN -> signed token) ──────────────────────────────────────
# HMAC key for rep session tokens. REQUIRED in production: when
# NODE_ENV=production the server REFUSES TO BOOT if this is unset, blank,
# shorter than 32 chars, or the publicly-known dev fallback. Generate with:
#   openssl rand -hex 32
# BEATS_TOKEN_SECRET=
# BEATS_SESSION_HOURS=12
# BEATS_PIN_MAX_ATTEMPTS=5
# BEATS_PIN_LOCKOUT_MIN=15

# ── REAL data ingestion (scripts/ingest.js) ─────────────────────────────────
# Tracerfy Property Data API token (PAID, ~$0.20 / property lookup). Leave UNSET
# to run ingestion fully free on Overpass + Census (uses the deterministic stub
# for property facts; no charges). NEVER commit a real value.
# TRACERFY_API_TOKEN=

# US Census ACS API key (FREE — get one at
# https://api.census.gov/data/key_signup.html). Without it, ingestion still
# geocodes addresses (keyless) but uses a NEUTRAL income band instead of real
# ACS demographics. NEVER commit a real value.
# CENSUS_API_KEY=

# Hard cap on PAID Tracerfy lookups per ingestion run (CLI --max overrides).
# Default 25. Estimated spend ≈ MAX_LOOKUPS * $0.20.
# MAX_LOOKUPS=25
